# Copy to .env and fill in what you have. .env is gitignored — never committed.
# The agent picks the first credential it finds (or force one via TECHRADAR_LLM).

# --- LLM provider (any ONE is enough for the research agent) ---
GROQ_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Force a specific provider: anthropic | groq | gemini | ollama
# TECHRADAR_LLM=groq
# Override the provider's default model:
# TECHRADAR_LLM_MODEL=llama-3.3-70b-versatile

# --- Optional ---
# GitHub API token for the github_releases connector (falls back to `gh auth token`)
# GITHUB_TOKEN=
# Local Ollama endpoint (if TECHRADAR_LLM=ollama)
# OLLAMA_HOST=http://localhost:11434
# Relocate the data directory (SQLite + Chroma)
# TECHRADAR_DATA_DIR=/path/to/data
